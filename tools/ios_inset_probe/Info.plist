<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key><string>InsetProbe</string>
    <key>CFBundleIdentifier</key><string>com.balatroportrait.insetprobe</string>
    <key>CFBundleName</key><string>InsetProbe</string>
    <key>CFBundlePackageType</key><string>APPL</string>
    <key>CFBundleShortVersionString</key><string>1.0</string>
    <key>CFBundleVersion</key><string>1</string>
    <!-- UILaunchScreen (even empty) opts into edge-to-edge layout; without it
